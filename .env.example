# Next.js (frontend)
NEXT_PUBLIC_API_URL=http://localhost:8000

# FastAPI (backend) - optional for production Vapi integration
VAPI_API_KEY=your_vapi_api_key_here
CORS_ORIGIN=http://localhost:3000

# GA4 Analytics (admin hub) — for live company metrics
# 1. Create a Google Cloud project, enable "Google Analytics Data API"
# 2. Create a service account, download JSON key
# 3. Add the service account as a viewer to your GA4 property (Admin → Property Access Management)
# 4. Either: set GOOGLE_APPLICATION_CREDENTIALS=/path/to/key.json
#    Or: paste the full JSON as GA4_CREDENTIALS_JSON (for Vercel)
GA4_CREDENTIALS_JSON={"type":"service_account",...}
GA4_NOVATION_HVAC_PROPERTY_ID=123456789

# Inquiry form — email notifications (Resend)
# Get API key at resend.com. Add INQUIRY_NOTIFY_EMAIL_2 for a second recipient.
RESEND_API_KEY=re_xxxxxxxxxxxx
INQUIRY_NOTIFY_EMAIL=you@intentrev.net
INQUIRY_NOTIFY_EMAIL_2=
RESEND_FROM_EMAIL=Intent <noreply@intentrev.net>
