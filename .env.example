# Copy values into .env.local for local dev (same names as Vercel). .env.local is gitignored.
#
# Next.js (frontend)
NEXT_PUBLIC_API_URL=http://localhost:8000

# FastAPI (backend) - optional for production Vapi integration
VAPI_API_KEY=your_vapi_api_key_here
CORS_ORIGIN=http://localhost:3000

# GA4 Analytics (admin hub) — for live company metrics
# 1. Create a Google Cloud project, enable "Google Analytics Data API"
# 2. Create a service account, download JSON key
# 3. Add the service account as a viewer to your GA4 property (Admin → Property Access Management)
# 4. Either: set GOOGLE_APPLICATION_CREDENTIALS=/path/to/key.json
#    Or: paste the full JSON as GA4_CREDENTIALS_JSON (for Vercel)
GA4_CREDENTIALS_JSON={"type":"service_account",...}
GA4_NOVATION_HVAC_PROPERTY_ID=123456789

# Inquiry form — email notifications (Resend)
# Get API key at resend.com. Add INQUIRY_NOTIFY_EMAIL_2 for a second recipient.
RESEND_API_KEY=re_xxxxxxxxxxxx
INQUIRY_NOTIFY_EMAIL=you@intentrev.net
INQUIRY_NOTIFY_EMAIL_2=
RESEND_FROM_EMAIL=Intent <noreply@intentrev.net>

# Optional: suppresses GCE metadata probes on Vercel/Docker (avoids MetadataLookupWarning in logs).
# METADATA_SERVER_DETECTION=none

# Google Ads API (Keyword Planner / demand research) — server-side only
# Developer token from Google Ads → Tools → API Center. Use same GCP project as OAuth below.
GOOGLE_ADS_DEVELOPER_TOKEN=
# OAuth 2.0 Web client (Google Cloud → APIs & Services → Credentials)
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
# From OAuth flow (offline access) — long-lived refresh token
GOOGLE_ADS_REFRESH_TOKEN=
# Customer ID you act on (no dashes), e.g. 1234567890
# If your developer token is still "test" access only, this MUST be a Google Ads *test* account ID.
# Production / MCC IDs require Basic or Standard API access (API Center).
GOOGLE_ADS_CUSTOMER_ID=
# When CUSTOMER_ID is a *client* under a manager: set this to the **manager (MCC)** ID (required by Google).
# Test hierarchy: use test **manager** ID here and test **client** ID in GOOGLE_ADS_CUSTOMER_ID.
# If you operate only on the manager account itself, some setups use the same ID for both or omit—see Google Ads API call docs.
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
#
# Refresh token (one-time OAuth): OAuth 2.0 Playground — https://developers.google.com/oauthplayground/
# 1. Gear icon → check "Use your own OAuth credentials" → paste Client ID + Secret (Web client).
# 2. Step 1: scope https://www.googleapis.com/auth/adwords → Authorize APIs (use a test user if app is in Testing).
# 3. Step 2: Exchange authorization code for tokens → copy refresh_token into GOOGLE_ADS_REFRESH_TOKEN.
# Customer ID: Google Ads UI, 10 digits without dashes (same account you authorized).
